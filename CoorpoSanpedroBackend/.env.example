# =========================================
# Variables de entorno para Railway
# Copiar este archivo a .env para desarrollo local
# En Railway: configurar en el panel Variables
# =========================================

# --- Base de datos PostgreSQL (Railway la provee automáticamente) ---
DB_HOST=nozomi.proxy.rlwy.net
DB_PORT=13379
DB_NAME=festival
DB_USER=postgres
DB_PASS=

# --- JWT ---
# Mínimo 32 caracteres, usar un valor seguro en producción
JWT_SECRET=

# --- Correo (OTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@corposanpedro.com
# App Password de Gmail (no la contraseña normal)
MAIL_PASSWORD=

# --- S3 / Tigris Storage ---
S3_ENDPOINT_URL=https://t3.storageapi.dev
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_REGION=us-east-1
